            .top-div {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .bottom-div {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .card {
                padding: 12px;
            }

            .card-title {
                font-size: 12.5px;
            }
            /* Pie — legend + chart side by side */
            .pie-body {
