            }

            .page {
                height: calc(100vh - 48px);
                padding: 8px 14px;
                gap: 8px;
                overflow: hidden;
            }

            .kpi-strip {
                gap: 8px;
            }

            .top-div {
                flex: 1;
                min-height: 0;
                gap: 8px;
                align-items: stretch;
            }

            .bottom-div {
                flex: 1;
                min-height: 0;
                gap: 8px;
                align-items: stretch;
            }

            .card {
                overflow: hidden;
                min-height: 0;
                padding: 12px 14px;
                display: flex;
                flex-direction: column;
            }

            .pie-body {
                flex: 1;
                min-height: 0;
            }

            .pie-chart-wrap {
                min-height: 0;
            }

                .pie-chart-wrap canvas {
                    max-height: 175px;
                }

            .bar-chart-wrap {
                flex: 1;
                min-height: 0;
                height: auto;
            }

            .hbar-chart-wrap {
                flex: 1;
                min-height: 0;
                height: auto;
            }

            .rank-list {
                flex: 1;
                justify-content: space-between;
                overflow: hidden;
                gap: 4px;
            }

            .progress-list {
                flex: 1;
                justify-content: space-between;
            }

            .logo-text {
                display: inline;
            }

            .user-name {
                display: inline;
            }

            .dept-label {
                display: inline;
            }

            #rankList {
                gap: 4px;
            }

                #rankList .rank-row {
                    padding: 5px 8px;
                }

                #rankList .rank-badge {
                    width: 24px;
                    height: 24px;
                    font-size: 12px;
                }

                #rankList .rank-avatar {
                    width: 26px;
                    height: 26px;
                    font-size: 10px;
                }

                #rankList .rank-name {
                    font-size: 10.5px;
                }

                #rankList .rank-orders {
                    font-size: 9.5px;
                }

                #rankList .rank-pill {
                    font-size: 9.5px;
                    padding: 1px 6px;
                }
        }

        /* LARGE TABLET / ZENBOOK FOLD 1024px–1279px
           iPad Pro 1024px landscape */
        @@media (min-width: 1024px) and (max-width: 1279px) {
            body {
                overflow-x: hidden;
            }

            .page {
                padding: 10px 14px 20px;
                gap: 10px;
            }

            .kpi-strip {
                grid-template-columns: repeat(4,1fr);
                gap: 8px;
            }

            .kpi-value {
                font-size: 19px;
            }

            .kpi-label {
                font-size: 9px;
            }

            .kpi-sub {
                font-size: 10px;
            }

            .top-div {
                grid-template-columns: 1fr 1.4fr 1fr;
                gap: 10px;
            }

            .bottom-div {
                grid-template-columns: 1.5fr 1fr 1fr;
                gap: 10px;
            }

            .card {
                padding: 12px 12px;
            }

            .bar-chart-wrap {
                height: 240px;
            }

            .hbar-chart-wrap {
                height: 280px;
            }

            .logo-text {
                display: inline;
            }

            .user-name {
                display: none;
            }

            .dept-label {
                display: inline;
            }

            .header-user {
                padding: 5px 8px;
            }
        }

        /* TABLET LANDSCAPE 768px–1023px - iPad Mini / Air landscape, iPad Pro portrait */
        @@media (min-width: 768px) and (max-width: 1023px) {
            body {
                overflow-x: hidden;
            }

            .page {
                padding: 10px 14px 20px;
                gap: 10px;
            }
            /* Header */
            .logo-text {
                display: inline;
            }

            .user-name {
                display: none;
            }

            .dept-label {
                display: inline;
            }

            .header-user {
                padding: 5px 8px;
            }

            .header-sep {
                margin: 0 10px;
            }
            /* KPI — 4 in a row but smaller */
            .kpi-strip {
                grid-template-columns: repeat(4,1fr);
                gap: 8px;
            }

            .kpi-card {
                min-height: 85px;
                padding: 12px 12px 10px;
            }

            .kpi-value {
                font-size: 17px;
            }

            .kpi-label {
                font-size: 8.5px;
            }

            .kpi-sub {
                font-size: 9.5px;
            }

            .kpi-growth {
                font-size: 10px;
            }

            .kpi-icon svg {
                width: 30px;
                height: 30px;
            }
            /* Charts — 1 column stack for clarity */
            .top-div {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }

            .bottom-div {
                grid-template-columns: 1fr 1fr;
                gap: 10px;
            }

            .card {
                padding: 12px 12px;
            }

            .card-title {
                font-size: 12.5px;
            }
            /* Pie — side by side on tablet */
            .pie-body {
                flex-direction: row;
                gap: 10px;
            }

            .pie-legend {
                flex: 0 0 44%;
            }

            .pie-chart-wrap canvas {
                max-height: 160px;
            }

            .bar-chart-wrap {
                height: 220px;
            }

            .hbar-chart-wrap {
                height: 280px;
            }
            /* Rank */
            .rank-list {
                gap: 5px;
            }

            .rank-row {
                padding: 5px 8px;
            }

            .rank-badge {
                width: 24px;
                height: 24px;
                font-size: 11px;
            }

            .rank-avatar {
                width: 26px;
                height: 26px;
                font-size: 10px;
            }

            .rank-name {
                font-size: 10.5px;
            }

            .rank-orders {
                font-size: 9.5px;
            }

            .rank-pill {
                font-size: 9.5px;
                padding: 1px 6px;
            }
        }

        /* SMALL TABLET / LARGE PHONE 600px–767p - iPad Mini portrait, Samsung large phones */
        @@media (min-width: 600px) and (max-width: 767px) {
            body {
                overflow-x: hidden;
            }

            .page {
                padding: 10px 12px 20px;
                gap: 10px;
            }
            /* Header */
            .logo-text {
                display: none;
            }

            .user-name {
                display: none;
            }

            .dept-label {
                display: inline;
