            .rank-avatar {
                width: 24px;
                height: 24px;
                font-size: 9px;
            }

            .rank-name {
                font-size: 10.5px;
            }

            .rank-orders {
                font-size: 9.5px;
            }

            .rank-pill {
                font-size: 9.5px;
                padding: 1px 6px;
            }

            .notif-dropdown {
                width: calc(100vw - 28px);
                right: -40px;
            }
        }

        /*MOBILE ≤ 599px - Samsung Galaxy A51/71, smaller phones*/
        @@media (max-width: 599px) {
            body {
                overflow-x: hidden;
