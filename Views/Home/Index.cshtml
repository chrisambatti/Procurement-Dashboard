    // OPEN TABLE
    function openTable(type) {
        const modal = document.getElementById("tableModal");
        const head = document.getElementById("tableHead");
        const body = document.getElementById("tableBody");
        const title = document.getElementById("modalTitle");

        modal.classList.add("open");

        const data = fullData[type];

        console.log("TYPE:", type);
        console.log("DATA:", data);

        head.innerHTML = "";
        body.innerHTML = "";

        if (!data || data.length === 0) {
            body.innerHTML = `<tr><td colspan="3">No data available</td></tr>`;
            title.innerText = "No Data";
            return;
        }

        // ITEMS TABLE
        if (type === "items") {
            title.innerText = "Items by Order Value";

            head.innerHTML = `
                    <tr>
                        <th>SR No.</th>
                        <th>Item Code</th>
                        <th>Item Name</th>
                        <th>Total Orders</th>
                    </tr>
                `;

            data.forEach(d => {
                body.innerHTML += `
                        <tr>
                            <td>${d.srno}</td>
                            <td>${d.itemcode}</td>
                            <td>${d.itemname}</td>
                            <td>${d.orders}</td>
                        </tr>
                    `;
            });

            return;
        }

        // RANK TABLE
        if (type === "rank") {
            title.innerText = "All Suppliers by Order Count";

            head.innerHTML = `
                    <tr>
                        <th>SR No.</th>
                        <th>Supplier Code</th>
                        <th>Supplier</th>
                        <th>Orders</th>
                    </tr>
                `;

            data.forEach(d => {
                body.innerHTML += `
                        <tr>
                            <td>${d.srno}</td>
                            <td>${d.suppliercode}</td>
                            <td>${d.supplier}</td>
                            <td>${d.orders}</td>
                        </tr>
                    `;
            });

            return;
        }

        //ORDERS - Supplier by Order Value

        if (type === "order") {
            title.innerText = "Top Orders by Supplier";

            head.innerHTML = `
        <tr>
            <th>SR No.</th>
            <th>Supplier Code</th>
            <th>Supplier Name</th>
            <th>Value</th>
        </tr>
    `;

            const grouped = Object.values(
                data.reduce((acc, curr) => {
                    if (!acc[curr.supplier]) {
                        acc[curr.supplier] = {
                            suppliercode: curr.suppliercode,
                            supplier: curr.supplier,
                            value: 0
                        };
                    }
                    acc[curr.supplier].value += curr.value;
                    return acc;
                }, {})
            );

            const sorted = grouped
                .sort((a, b) => b.value - a.value)
                .slice(0, 5);

            sorted.forEach((d, index) => {
                body.innerHTML += `
        <tr>
            <td>${index + 1}</td>
            <td>${d.suppliercode}</td>
            <td>${d.supplier}</td>
            <td>${Number(d.value).toLocaleString()}</td>
