@{
    Layout = null;
    ViewData["Title"] = "Aegle Procurement Dashboard";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Aegle - Dashboard GCPO</title>
    <link rel="icon" class="favicon" type="image/png" href="/images/favicon.png" asp-append-version="true" />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    <style>

        .favicon {
            height: 32px;
        }

        /* ── LIGHT TOKENS ── */
        :root, [data-theme="light"] {
            --bg: #F4F6FB;
            --header: #4A7FD4;
            --card: #FFFFFF;
            --radius: 10px;
            --shadow: 0 2px 12px rgba(74,127,212,0.10);
            --text: #1E2A45;
            --muted: #7B8FAD;
            --blue: #4A7FD4;
            --border: #EEF2FA;
            --rank-bg: #F8FAFF;
            --prog-track: #EEF2FA;
            --notif-unread: #F0F5FF;
            --notif-hover: #E8F0FF;
            --dd-bg: #FFFFFF;
            --dd-hover: #F4F6FB;
        }

        /* ── DARK TOKENS ── */
        /* [data-theme="dark"] {
            --bg: #0F1624;
            --header: #1A2540;
            --card: #1A2540;
            --radius: 10px;
            --shadow: 0 2px 12px rgba(0,0,0,0.3);
            --text: #E2E8F4;
            --muted: #6B82A8;
            --blue: #5B8FE8;
            --border: #243050;
            --rank-bg: #1E2D4D;
            --prog-track: #243050;
            --notif-unread: #1E2D4D;
            --notif-hover: #243050;
            --dd-bg: #1A2540;
            --dd-hover: #243050;
        } */

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 13px;
            min-height: 100%;
            transition: background 0.3s ease, color 0.3s ease;
            margin: 0;
            padding: 0;
            height: 100%;

        }

        /* ── HEADER ── */
        .header {
            background: var(--header);
            height: 57px;
            display: flex;
            align-items: center;
            padding: 0 15px;
            flex-shrink: 0;
            position: sticky;
            top: 0;
            z-index: 300;
            transition: background 0.3s ease;
        }

        .header-logo {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #fff;
            font-weight: 700;
            font-size: 20px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .logo-text {
            display: inline;
        }

        .header-sep {
            width: 1px;
            height: 22px;
            background: rgba(255,255,255,0.3);
            margin: 0 16px;
            flex-shrink: 0;
        }

        .header-spacer {
            flex: 1;
        }

        .header-right {
            display: flex;
            align-items: center;
            flex-shrink: 0;
            gap: 4px;
        }

        .logo {
            width: 28px;
            height: 28px;
            display: flex;
            align-items: center;
            font-family: sans serif;
            justify-content: center;
            font-size: 12px;
            color: #fff;
            flex-shrink: 0;
        }

        /* ── DEPT BUTTON ─── */
        .dept-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.25);
            border-radius: 8px;
            padding: 5px 12px;
            color: #fff;
            font-family: 'DM Sans',sans-serif;
            font-size: 13px;
            font-weight: 500;
            white-space: nowrap;
            height: 32px;
            flex-shrink: 0;
        }
        
        .dept-btn-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #A7F3D0;
            flex-shrink: 0;
        }

        .dept-label {
            display: inline;
        }

        /* ── THEME TOGGLE ── */
        .theme-toggle {
            position: relative;
            width: 52px;
            height: 28px;
            flex-shrink: 0;
            cursor: pointer;
        }

        .theme-toggle input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute;
            }

        .toggle-track {
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0.15);
            border: 1.5px solid rgba(255,255,255,0.3);
            border-radius: 999px;
            transition: background 0.3s ease, border-color 0.3s ease;
        }

        .theme-toggle input:checked + .toggle-track {
            background: rgba(255,255,255,0.25);
            border-color: rgba(255,255,255,0.5);
        }

        .toggle-thumb {
            position: absolute;
            top: 3px;
            left: 3px;
            width: 20px;
            height: 20px;
            background: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.3s cubic-bezier(.4,0,.2,1), background 0.3s ease;
            box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        }

        .theme-toggle input:checked ~ .toggle-thumb {
            transform: translateX(24px);
            background: #1A2540;
        }

        .toggle-thumb svg {
            width: 12px;
            height: 12px;
            flex-shrink: 0;
        }

        .icon-sun {
            display: block;
            color: #F59E0B;
        }

        .icon-moon {
            display: none;
            color: #A7F3D0;
        }

        .theme-toggle input:checked ~ .toggle-thumb .icon-sun {
            display: none;
        }

        .theme-toggle input:checked ~ .toggle-thumb .icon-moon {
            display: block;
        }

        /* ── BELL ── */
        .bell-wrap {
            position: relative;
        }

        .header-bell {
            position: relative;
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            border-radius: 8px;
            transition: background .15s;
        }

        .header-bell:hover {
            background: rgba(255,255,255,0.12);
        }

        .header-bell svg {
            color: rgba(255,255,255,0.9);
        }

        .bell-dot {
            position: absolute;
            top: 7px;
            right: 7px;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #4ADE80;
            border: 1.5px solid var(--header);
        }

        /* ── NOTIF DROPDOWN ── */
        .notif-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 300px;
            background: var(--dd-bg);
            border-radius: 12px;
            border: 1px solid var(--border);
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            overflow: hidden;
            z-index: 999;
            animation: dropIn 0.18s ease;
        }

        .notif-dropdown.open {
            display: block;
        }

        .notif-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px 10px;
            border-bottom: 1px solid var(--border);
        }

        .notif-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--text);
        }

        .notif-count {
            font-size: 11px;
            font-weight: 600;
            color: #fff;
            background: #5B8FE8;
            padding: 2px 8px;
            border-radius: 20px;
        }

        .notif-item {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 11px 16px;
            cursor: pointer;
            transition: background .12s;
            border-bottom: 1px solid var(--border);
        }

        .notif-item:last-child {
            border-bottom: none;
        }

        .notif-item:hover {
            background: var(--dd-hover);
        }

        .notif-item.unread {
            background: var(--notif-unread);
        }

        .notif-item.unread:hover {
            background: var(--notif-hover);
        }

        .notif-icon-wrap {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .notif-icon-wrap.blue {
            background: #EEF4FF;
            color: #5B8FE8;
        }

        .notif-icon-wrap.green {
            background: #ECFDF5;
            color: #2CB5A0;
        }

        .notif-icon-wrap.orange {
            background: #FFFBEB;
            color: #F0A030;
        }

        .notif-icon-wrap.purple {
            background: #F5F3FF;
            color: #7C6FD4;
        }

        .notif-icon-wrap.red {
            background: #FEF2F2;
            color: #E85B6F;
        }

        .notif-body {
            flex: 1;
            min-width: 0;
        }

        .notif-msg {
            font-size: 12px;
            color: var(--text);
            line-height: 1.45;
        }

        .notif-msg strong {
            color: var(--text);
            font-weight: 600;
        }

        .notif-time {
            font-size: 10.5px;
            color: var(--muted);
            margin-top: 3px;
        }

        .notif-unread-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #5B8FE8;
            flex-shrink: 0;
            margin-top: 4px;
        }

        .notif-footer {
            padding: 11px 16px;
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            color: #5B8FE8;
            cursor: pointer;
            transition: background .12s;
            border-top: 1px solid var(--border);
        }

        .notif-footer:hover {
            background: var(--dd-hover);
        }

        /* ── USER ── */
        .user-wrap {
            position: relative;
        }

        .header-user {
            display: flex;
            align-items: center;
            gap: 6px;
            color: rgba(255,255,255,0.95);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            padding: 5px 10px;
            border-radius: 8px;
            transition: background .15s;
            user-select: none;
        }

        .header-user:hover {
            background: rgba(255,255,255,0.12);
        }

        .user-name {
            display: inline;
        }

        .user-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        /* ── USER DROPDOWN ── */
        .user-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 245px;
            background: var(--dd-bg);
            border-radius: 12px;
            border: 1px solid var(--border);
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            overflow: hidden;
            z-index: 999;
            animation: dropIn 0.18s ease;
        }

        .user-dropdown.open {
            display: block;
        }

        @@keyframes dropIn {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
       }

        .dropdown-header {
            padding: 16px;
            background: linear-gradient(135deg,#5B8FE8,#3A6BC4);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dropdown-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: rgba(255,255,255,0.25);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .dropdown-name {
            color: #fff;
            font-weight: 700;
            font-size: 13px;
            line-height: 1.2;
        }

        .dropdown-role {
            color: rgba(255,255,255,0.75);
            font-size: 10.5px;
            margin-top: 2px;
        }

        .dropdown-divider {
            height: 1px;
            background: var(--border);
            margin: 4px 0;
        }

        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 16px;
            color: var(--text);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: background .12s;
        }

            .dropdown-item:hover {
                background: var(--dd-hover);
            }

            .dropdown-item svg {
                color: var(--muted);
                flex-shrink: 0;
            }

            .dropdown-item.logout {
                color: #EF4444;
            }

                .dropdown-item.logout svg {
                    color: #EF4444;
                }

                .dropdown-item.logout:hover {
                    background: #FEF2F2;
                }

        /* ── PAGE ── */
        .page {
            /*height: calc(100vh - 57px);*/ /* match header height exactly */
            /*display: flex;
            flex-direction: column;*/
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── KPI STRIP ── */
        .kpi-strip {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 10px;
        }

        .kpi-card {
            background: #337ab7;
            border-radius: var(--radius);
            padding: 14px 16px 12px;
            color: #fff;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(74,127,212,0.22);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 110px;
        }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: -20px;
            right: -20px;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: rgba(255,255,255,0.06);
            opacity: 0.8;
        }

        .kpi-card::after {
            content: '';
            position: absolute;
            bottom: -30px;
            left: -10px;
            width: 80px;
            height: 80px;
            border-radius: 50%;
                /* background: rgba(255,255,255,0.04); */
        }

        .kpi-label {
            font-size: 9.5px;
            font-weight: 600;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.7);
            margin-bottom: 4px;
        }

        .kpi-icon {
            position: absolute;
            top: 12px;
            right: 12px;
            color: rgba(255,255,255,0.2);
        }

        .kpi-value {
            font-size: 22px;
            font-weight: 700;
            line-height: 1.15;
            color: #fff;
            word-break: break-word;
        }

        .kpi-sub {
            font-size: 10.5px;
            color: rgba(255,255,255,0.6);
            margin-top: 2px;
            color:#fff;
        }

        .kpi-growth {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            font-weight: 600;
            margin-top: 6px;
        }

        .kpi-growth.up {
            color: #A7F3D0;
        }

        .kpi-growth.down {
            color: #FECACA;
        }

        /* ── CARD ──*/
        .card {
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 10px 20px;
            display: flex;
            flex-direction: column;
            transition: background 0.3s ease;
        }
     
        .card-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 2px;
        }

        .card-title {
            font-size: 13px;
            font-weight: 700;
            color: var(--blue);
        }

        .card-badge {
            font-size: 10px;
            font-weight: 600;
            color: var(--muted);
            background: var(--prog-track);
            padding: 2px 8px;
            border-radius: 20px;
            white-space: nowrap;
            cursor:pointer;
        }

        .card-sub {
            font-size: 10.5px;
            color: var(--muted);
            margin-bottom: 10px;
        }

        /* ── GRIDS ──── */
        .top-div {
            display: grid;
            grid-template-columns: 0.90fr 1.9fr 1fr;
            gap: 12px;
        }

        .bottom-div {
            display: grid;
            grid-template-columns: 1.6fr 1fr 1fr;
            gap: 12px;
        }

        /* ── PIE ── */
        .pie-body {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .pie-legend {
            flex: 0 0 46%;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .legend-row {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .legend-name {
            flex: 1;
            color: var(--text);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-size: 10.5px;
        }

        .legend-pct {
            font-weight: 700;
            color: var(--blue);
            font-size: 11px;
            white-space: nowrap;
        }

        .legend-divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 6px 0;
        }

        .legend-total {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .legend-total-label {
            color: var(--muted);
            font-size: 11px;
        }

        .legend-total-val {
            font-weight: 700;
            color: var(--text);
            font-size: 12px;
        }

        .pie-chart-wrap {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pie-chart-wrap canvas {
            max-height: 180px;
        }

        .bar-chart-wrap {
            height: 240px;
            position: relative;
        }

        .hbar-chart-wrap {
            height: 280px;
            position: relative;
        }

        /* ── RANK LIST ── */
        .rank-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .rank-row {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 10px;
            border-radius: 7px;
            background: var(--rank-bg);
            opacity: 0;
            transform: translateY(6px);
            animation: slideIn 0.35s ease forwards;
            transition: background 0.3s ease;
        }

        @@keyframes slideIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .rank-badge {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            flex-shrink: 0;
        }

        .rank-badge.gold {
            background: #FEF3C7;
        }

        .rank-badge.silver {
            background: #F1F5F9;
        }

        .rank-badge.bronze {
            background: #FEF0E6;
        }

        .rank-badge.plain {
            background: var(--prog-track);
            font-weight: 700;
            font-size: 12px;
            color: var(--blue);
        }

        .rank-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: linear-gradient(135deg,#5B8FE8,#7C6FD4);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: 11px;
            flex-shrink: 0;
        }

        .rank-info {
            flex: 1;
            min-width: 0;
        }

        .rank-name {
            font-size: 11px;
            font-weight: 600;
            color: var(--text);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .rank-orders {
            font-size: 10px;
            color: var(--muted);
        }

        .rank-pill {
            font-size: 10px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 20px;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .rank-pill.p1 {
            background: #FEF3C7;
            color: #92400E;
        }

        .rank-pill.p2 {
            background: #F1F5F9;
            color: #374151;
        }

        .rank-pill.p3 {
            background: #FEF0E6;
            color: #7C2D12;
        }

        .rank-pill.p4, .rank-pill.p5 {
                background: var(--prog-track);
                color: var(--muted);
            }

        /* ── PROGRESS BARS ── */
        .progress-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .prog-row-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 4px;
            gap: 6px;
        }

        .prog-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .prog-rank-circle {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .prog-name {
            flex: 1;
            font-size: 11px;
            font-weight: 500;
            color: var(--text);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .prog-amount {
            font-size: 11.5px;
            font-weight: 700;
            color: var(--text);
            white-space: nowrap;
        }

        .prog-track {
            width: 100%;
            height: 10px;
            border-radius: 5px;
