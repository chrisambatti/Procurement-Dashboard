                width: 17px;
                height: 17px;
                top: 3px;
                left: 3px;
            }

            .theme-toggle input:checked ~ .toggle-thumb {
                transform: translateX(20px);
            }
            /* Page */
            .page {
                padding: 8px 10px 24px;
                gap: 8px;
                overflow-x: hidden;
                width: 100%;
            }
            /* KPI — 2 per row */
            .kpi-strip {
                grid-template-columns: repeat(2,1fr);
                gap: 7px;
                width: 100%;
            }

            .kpi-card {
                min-height: 82px;
                padding: 10px 10px 8px;
                min-width: 0;
                width: 100%;
            }

            .kpi-value {
                font-size: 17px;
            }

            .kpi-label {
                font-size: 8px;
            }

            .kpi-sub {
                font-size: 9px;
            }

            .kpi-growth {
                font-size: 9.5px;
            }

            .kpi-icon svg {
                width: 28px;
                height: 28px;
            }
            /* Charts — single column */
            .top-div {
                grid-template-columns: 1fr;
                width: 100%;
                gap: 8px;
            }

            .bottom-div {
                grid-template-columns: 1fr;
                width: 100%;
                gap: 8px;
            }
            /* Cards */
            .card {
                width: 100%;
                min-width: 0;
                overflow: hidden;
                padding: 10px;
            }

            .card-title {
                font-size: 12px;
            }

            .card-sub {
                font-size: 10px;
                margin-bottom: 8px;
            }
            /* Pie — legend stacks above */
            .pie-body {
                flex-direction: column;
                gap: 12px;
                width: 100%;
            }

            .pie-legend {
                flex: none;
                width: 100%;
            }

            .pie-chart-wrap {
                width: 100%;
                height: 200px;
                justify-content: center;
            }

                .pie-chart-wrap canvas {
                    max-height: 190px;
                    max-width: 190px;
                }
            /* Bar charts */
            .bar-chart-wrap {
                height: 240px;
                width: 100%;
                overflow: hidden;
            }

            .hbar-chart-wrap {
                height: 300px;
                width: 100%;
                overflow: hidden;
            }
            /* Rank — super compact */
            .rank-list {
                gap: 3px;
            }

            .rank-row {
                padding: 4px 7px;
                gap: 5px;
                border-radius: 6px;
            }

            .rank-badge {
                width: 21px;
                height: 21px;
                font-size: 10px;
            }

            .rank-avatar {
                width: 23px;
                height: 23px;
                font-size: 9px;
            }

            .rank-name {
                font-size: 10px;
            }

            .rank-orders {
                font-size: 9px;
            }

            .rank-pill {
                font-size: 9px;
                padding: 1px 5px;
            }
            /* Notification dropdown */
            .notif-dropdown {
                width: calc(100vw - 24px);
                right: -30px;
            }
        }

        /* VERY SMALL ≤ 380px */
        @@media (max-width: 380px) {
            .kpi-strip {
                grid-template-columns: 1fr 1fr;
                gap: 6px;
            }

            .kpi-value {
                font-size: 16px;
            }

            .kpi-label {
                font-size: 7.5px;
            }

            .page {
                padding: 8px 8px 20px;
            }
        }

        /* Footer */
        .footer {
            text-align: center;
            font-size: 12px;
            color: var(--muted);
            text-decoration: none;
            font-weight: 500;
        }

        .table-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 1000;
            align-items: center;
            text-align:center;
            justify-content: center;

        }

        .table-modal.open {
            display: flex;
        }

        .table-modal-content {
            width: 80%;
            max-width: 900px;
            max-height: 80vh;
            background: var(--card);
            border-radius: 12px;
            overflow: hidden;
        }

        .table-modal-header {
            padding: 14px;
            display: flex;
            justify-content: space-between;
            border-bottom: 1px solid var(--border);
            font-weight:700;
        }

        .close-btn {
            cursor: pointer;
            height:20px;
            width:20px;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;

        }

        .data-table th,
        .data-table td {
           padding: 10px;
           border-bottom: 1px solid var(--border);
        }
    </style>
</head>
